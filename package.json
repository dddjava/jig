{
  "name": "jig-js-tests",
  "private": true,
  "scripts": {
    "test": "node --test jig-core/src/test/js/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage jig-core/src/test/js/*.test.js",
    "test:contract": "./gradlew :jig-core:contractTest -q && npm run test:contract:js",
    "test:contract:js": "node --test jig-core/src/test/js/contract/*.test.js",
    "test:full": "npm run test && ./gradlew clean test contractTest && npm run test:contract:js",
    "test:pr": "npm run lint:css && npm run test && ./gradlew clean build qualityCheck && npm run test:contract:js",
    "lint:css": "stylelint \"jig-core/src/main/resources/templates/**/*.css\""
  },
  "devDependencies": {
    "dompurify": "3.4.12",
    "jsdom": "^29.1.1",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended": "^18.0.0"
  }
}
